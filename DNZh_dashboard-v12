function deficitChips(r){
  const out=[];
  DATA.events.rules.forEach(rule=>{
    const v=last(r[("P"+rule.pid.replace("П",""))]||[]);
    if(v!=null && v<rule.threshold)
      out.push(el("span",{class:"chip",style:"background:#fdecec;color:#b23636;border-color:#f6c9c9;margin:2px 4px 2px 0"},
        `${rule.pid} = ${v} (< ${rule.threshold})`));
  });
  if(!out.length)out.push(el("span",{style:"color:var(--ink-3);font-size:12px"},"дефицитных индексов нет"));
  return out;
}
function recommendedSet(r){
  const set=new Set();r.recs.forEach(x=>set.add(x.k));return set;
}
function drawSunburst(container,r){
  container.innerHTML="";
  const EV=DATA.events, rec=recommendedSet(r);
  const macroColor={"Вовлечение":C.people,"Развитие организаций":C.org,"Инфраструктура":C.infra,"Поддержка":C.support};
  const groups={};
  EV.events.forEach(e=>{(groups[e.macro]=groups[e.macro]||[]).push(e);});
  const root={name:"ДНЖ",children:Object.entries(groups).map(([g,evs])=>({name:g,color:macroColor[g],
    children:evs.map(e=>{let sz=1;try{sz=Math.log10((+String(e.default).replace(/\s/g,""))||10)+1;}catch(x){sz=1;}
      return {name:e.id,full:e.name,value:sz,rec:rec.has(e.id),color:macroColor[g]};})}))};
  const size=320,radius=size/2;
  const svg=d3.create("svg").attr("viewBox",`0 0 ${size} ${size}`).attr("width",size).attr("height",size).attr("class","viz");
  const g=svg.append("g").attr("transform",`translate(${radius},${radius})`);
  const part=d3.partition().size([2*Math.PI,radius]);
  const rootH=d3.hierarchy(root).sum(d=>d.value||0);
  part(rootH);
  const arc=d3.arc().startAngle(d=>d.x0).endAngle(d=>d.x1).innerRadius(d=>d.y0).outerRadius(d=>d.y1-1).padAngle(.006);
  g.selectAll("path").data(rootH.descendants().filter(d=>d.depth)).join("path")
    .attr("d",arc).attr("fill",d=>d.data.color||"#ccc")
    .attr("fill-opacity",d=>d.depth===1?.55:(d.data.rec?1:.85))
    .attr("stroke","#fff").attr("stroke-width",d=>d.data.rec?2:.5)
    .attr("class",d=>d.data.rec?"legend-pulse":"")
    .style("cursor","pointer")
    .on("mouseenter",(e,d)=>showTip(`<b>${d.data.name}</b>${d.data.full?"<br>"+d.data.full:""}${d.data.rec?'<br><span style="color:#F39C12">★ рекомендовано</span>':""}`,e))
    .on("mousemove",moveTip).on("mouseleave",hideTip);
  g.selectAll("text").data(rootH.descendants().filter(d=>d.depth===2&&(d.x1-d.x0)>.18)).join("text")
    .attr("transform",d=>{const a=(d.x0+d.x1)/2*180/Math.PI-90,rr=(d.y0+d.y1)/2;return `rotate(${a}) translate(${rr},0) rotate(${a>90?180:0})`;})
    .attr("text-anchor","middle").attr("dy",".35em").style("font-size","8.5px").style("fill","#fff").style("font-weight","700")
    .text(d=>d.data.name);
  g.append("circle").attr("r",rootH.children?rootH.y?40:42:42).attr("fill","#fff");
  g.append("text").attr("text-anchor","middle").attr("dy","-2").style("font-family","Boska").style("font-weight","700").style("font-size","13px").text("ДНЖ");
  g.append("text").attr("text-anchor","middle").attr("dy","14").style("font-size","9px").style("fill","#7b8794").text(r.name.slice(0,16));
  container.append(svg.node());
}
