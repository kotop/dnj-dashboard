function drawPressCard(){
  const cv=$("#pressCard");if(!cv)return;const x=cv.getContext("2d");const c=DATA.country;
  const grd=x.createLinearGradient(0,0,1200,628);grd.addColorStop(0,"#0f1d29");grd.addColorStop(1,"#143a2a");
  x.fillStyle=grd;x.fillRect(0,0,1200,628);
  x.fillStyle="#6fcf97";x.font="600 26px Satoshi, sans-serif";x.fillText("ДОБРО — НОРМА ЖИЗНИ",70,90);
  x.fillStyle="#9fb3c8";x.font="400 20px Satoshi, sans-serif";x.fillText("Сводный индекс по Российской Федерации",70,128);
  x.fillStyle="#ffffff";x.font="700 180px Boska, serif";x.fillText(String(last(c.total)),64,330);
  x.fillStyle="#6fcf97";x.font="400 30px Satoshi, sans-serif";
  const d=Math.round((last(c.total)-prev(c.total))*10)/10;x.fillText((d>=0?"▲ +":"▼ ")+d+" за период",70,385);
  const subs=[["Люди",last(c.people),"#27AE60"],["Организации",last(c.org),"#2E86C1"],["Инфраструктура",last(c.infra),"#F39C12"]];
  subs.forEach((s,i)=>{const bx=70+i*370;
    x.fillStyle="#1d3344";x.fillRect(bx,460,330,110);
    x.fillStyle=s[2];x.fillRect(bx,460,6,110);
    x.fillStyle="#9fb3c8";x.font="400 20px Satoshi, sans-serif";x.fillText(s[0],bx+28,500);
    x.fillStyle="#ffffff";x.font="700 56px Boska, serif";x.fillText(String(s[1]),bx+28,560);});
  x.fillStyle="#5d7488";x.font="400 17px Satoshi, sans-serif";
  x.fillText("Методика v5.0 · "+DATA.meta.date+" · dobro.ru",70,605);
}
function exportPressCard(){
  drawPressCard();const cv=$("#pressCard");
  const a=document.createElement("a");a.download="dnzh_press_"+DATA.meta.date.replace(/\./g,"-")+".png";
  a.href=cv.toDataURL("image/png");a.click();
}

