  const axis=!!opts.axis;
  const ch=new Chart(canvas,{type:"line",data:{labels,datasets:[
    {label:"факт",data:fact,borderColor:color,backgroundColor:"transparent",borderWidth:2,pointRadius:0,tension:.34},
    {label:"прогноз",data:fore,borderColor:color,borderDash:[4,3],backgroundColor:"transparent",borderWidth:1.6,pointRadius:0,tension:.34}]},
