  v.append(pageHead("L11 · Рейтинг","Рейтинг субъектов РФ",
    "Полная таблица регионов по Сводному индексу и субиндексам. Сортировка по любому столбцу, фильтры ФО/кластера применяются из шапки."));
  let sortKey="total", sortDir=-1;
  const card=el("div",{class:"card"});
  const head=el("div",{class:"card-h"},el("h3",{},"Все субъекты"),el("span",{class:"hint",id:"ratCount"},""));
  card.append(head);
  const host=el("div",{class:"scrollx"});card.append(host);v.append(card);
  function rows(){
    let list=DATA.regions.filter(r=>
      (state.fo==="all"||r.fo===state.fo)&&(state.cluster==="all"||r.cluster3===state.cluster));
    const getv=(r)=>sortKey==="name"?r.name:sortKey==="fo"?r.fo:sortKey==="cluster"?r.cluster3:last(r[sortKey]);
    list=list.sort((a,b)=>{const x=getv(a),y=getv(b);
      return (typeof x==="string"?x.localeCompare(y,"ru"):x-y)*sortDir;});
    return list;
  }
  function draw(){
    host.innerHTML="";
    const list=rows();
    $("#ratCount").textContent=`${list.length} субъектов`;
    const cols=[["",""],["name","Регион"],["fo","ФО"],["cluster","Кл."],
      ["total","Сводный"],["people","Люди"],["org","Орг."],["infra","Инфра"],["P1","П1"],["P3","П3"]];
    const tbl=el("table");
    const tr=el("tr",{});
    cols.forEach(([k,t])=>{
      const th=el("th",{style:k?"cursor:pointer;user-select:none":""},t+(k&&sortKey===k?(sortDir<0?" ▼":" ▲"):""));
      if(k)th.addEventListener("click",()=>{if(sortKey===k)sortDir*=-1;else{sortKey=k;sortDir=(k==="name"||k==="fo")?1:-1;}draw();});
      tr.append(th);
    });
    tbl.append(el("thead",{},tr));
    const tb=el("tbody");
    list.forEach((r,i)=>{
      const t=last(r.total);
      const cell=(key,col)=>{const val=last(r[key]);return el("td",{},el("span",{class:"num",style:`font-weight:700;color:${col||zoneColor(val)}`},val));};
      tb.append(el("tr",{class:"rowlink",onclick:()=>{state.region=r.code;go("region");}},
        el("td",{class:"num",style:"color:var(--ink-3)"},i+1),
        el("td",{},el("div",{style:"font-weight:600"},r.name)),
        el("td",{style:"color:var(--ink-3);font-size:12px"},r.fo),
        el("td",{class:"num",style:"color:var(--ink-3)"},r.cluster3),
        el("td",{},el("div",{style:"display:flex;align-items:center;gap:8px"},
          el("span",{class:"num",style:`font-weight:700;color:${zoneColor(t)}`},t),
          el("span",{class:"mini-gauge"},el("i",{style:`width:${t}%;background:${zoneColor(t)}`})))),
        cell("people",C.people),cell("org",C.org),cell("infra",C.infra),
        el("td",{class:"num"},last(r.P1)),el("td",{class:"num"},last(r.P3))));
    });
    tbl.append(tb);host.append(tbl);
  }
  setTimeout(draw,10);
};

