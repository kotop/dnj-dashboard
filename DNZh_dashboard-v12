/* ===== прогноз и мини-графики индикаторов (ретроспектива + прогноз) ===== */
function olsFc(series,horizon=4){
  const n=series.length, xs=[...Array(n).keys()];
  const mx=xs.reduce((a,b)=>a+b,0)/n, my=series.reduce((a,b)=>a+b,0)/n;
  let num=0,den=0; for(let i=0;i<n;i++){num+=(xs[i]-mx)*(series[i]-my);den+=(xs[i]-mx)**2;}
  const b=den?num/den:0, a=my-b*mx, out=[];
  for(let j=0;j<horizon;j++){const v=a+b*(n+j);out.push(Math.round(Math.max(0,Math.min(100,v))*10)/10);}
  return out;
}
