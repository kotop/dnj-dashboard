<script>
/* ---------- mobile sidebar: backdrop + auto-close ---------- */
(function(){
  var side=document.getElementById('side');
  var burger=document.getElementById('burger');
  var nav=document.getElementById('nav');
  if(!side||!burger) return;
  var scrim=document.getElementById('sideScrim');
  if(!scrim){ scrim=document.createElement('div'); scrim.id='sideScrim'; document.body.appendChild(scrim); }
  var mq=window.matchMedia('(max-width:860px)');
  function setOpen(open){
    side.classList.toggle('open', open);
    document.body.classList.toggle('side-open', open);
  }
  burger.addEventListener('click', function(e){
    e.stopPropagation();
    setOpen(!side.classList.contains('open'));
  });
  scrim.addEventListener('click', function(){ setOpen(false); });
  // close the drawer once a destination is chosen on mobile (nav is re-rendered, so delegate on the container)
  if(nav) nav.addEventListener('click', function(){ if(mq.matches) setOpen(false); });
  document.addEventListener('keydown', function(e){ if(e.key==='Escape') setOpen(false); });
  function onChange(){ if(!mq.matches) setOpen(false); }   // reset when leaving mobile width
  if(mq.addEventListener) mq.addEventListener('change', onChange);
  else window.addEventListener('resize', onChange);
})();
</script>
