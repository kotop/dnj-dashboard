function drawGraph(container,r){
  container.innerHTML="";
  const EV=DATA.events, rec=recommendedSet(r);
  const macroColor={"Вовлечение":C.people,"Развитие организаций":C.org,"Инфраструктура":C.infra,"Поддержка":C.support};
  const W=container.clientWidth||900,H=480;
  const nodesK=EV.events.map(e=>({id:e.id,type:"k",label:e.id,color:macroColor[e.macro],rec:rec.has(e.id),name:e.name}));
  const indSet={};EV.impact.forEach(m=>{indSet[m.ind]={id:m.ind,type:"ind",label:m.ind,base:m.base};});
  const nodesI=Object.values(indSet);
  const nodes=[...nodesK,...nodesI];
  const links=EV.impact.map(m=>({source:m.k,target:m.ind,w:m.w}));
  const svg=d3.create("svg").attr("viewBox",`0 0 ${W} ${H}`).attr("class","viz").attr("height",H);
  const link=svg.append("g").selectAll("line").data(links).join("line").attr("class","link")
    .attr("stroke-width",d=>1+d.w*5).attr("stroke",d=>{const n=nodesK.find(k=>k.id===d.source);return n&&n.rec?"#F39C12":"#cbd5e1";})
    .attr("stroke-opacity",d=>{const n=nodesK.find(k=>k.id===d.source);return n&&n.rec?.8:.4;});
  const node=svg.append("g").selectAll("g").data(nodes).join("g").style("cursor","pointer")
    .on("mouseenter",(e,d)=>showTip(d.type==="k"?`<b>${d.id}</b><br>${d.name}${d.rec?'<br><span style="color:#F39C12">★ рекомендовано</span>':""}`:`<b>${d.id}</b><br>индикатор · ${d.base}`,e))
    .on("mousemove",moveTip).on("mouseleave",hideTip);
  node.append("circle").attr("r",d=>d.type==="k"?(d.rec?13:10):6)
    .attr("fill",d=>d.type==="k"?d.color:"#fff").attr("stroke",d=>d.type==="k"?(d.rec?"#F39C12":"#fff"):"#94a3b8")
    .attr("stroke-width",d=>d.rec?3:1.5).attr("class",d=>d.rec?"legend-pulse":"");
  node.append("text").text(d=>d.label).attr("text-anchor","middle").attr("dy",d=>d.type==="k"?3.5:-9)
    .style("font-size",d=>d.type==="k"?"8.5px":"8px").style("font-weight",d=>d.type==="k"?"700":"500")
    .style("fill",d=>d.type==="k"?"#fff":"#475569").style("pointer-events","none");
  const sim=d3.forceSimulation(nodes)
    .force("link",d3.forceLink(links).id(d=>d.id).distance(60).strength(.4))
    .force("charge",d3.forceManyBody().strength(-120))
    .force("center",d3.forceCenter(W/2,H/2))
    .force("collide",d3.forceCollide(16));
  sim.on("tick",()=>{
    link.attr("x1",d=>d.source.x).attr("y1",d=>d.source.y).attr("x2",d=>d.target.x).attr("y2",d=>d.target.y);
    node.attr("transform",d=>`translate(${d.x=Math.max(14,Math.min(W-14,d.x))},${d.y=Math.max(14,Math.min(H-14,d.y))})`);
  });
  node.call(d3.drag().on("start",(e,d)=>{if(!e.active)sim.alphaTarget(.3).restart();d.fx=d.x;d.fy=d.y;})
    .on("drag",(e,d)=>{d.fx=e.x;d.fy=e.y;}).on("end",(e,d)=>{if(!e.active)sim.alphaTarget(0);d.fx=null;d.fy=null;}));
  container.append(svg.node());
}
